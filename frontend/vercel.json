{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/drops/:id/eligibility/:wallet", "destination": "/api/drops/[id]/eligibility/[wallet]" },
    { "source": "/api/drops/:id/recipients", "destination": "/api/drops/[id]/recipients" },
    { "source": "/api/drops/:id/claims", "destination": "/api/drops/[id]/claims" },
    { "source": "/api/drops/:id", "destination": "/api/drops/[id]" },
    { "source": "/api/analytics/:dropId", "destination": "/api/analytics/[dropId]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
